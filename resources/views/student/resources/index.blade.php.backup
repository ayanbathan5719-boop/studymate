@push('scripts')
<script>
document.querySelectorAll('.btn-study').forEach(button => {
    button.addEventListener('click', function() {
        const resourceId = this.getAttribute('data-resource-id');
        const resourceCard = this.closest('.resource-card');
        const titleLink = resourceCard?.querySelector('.resource-title a');
        const resourceTitle = titleLink?.innerText || 'this resource';
        
        // Clean confirmation dialog without emojis
        if (confirm(`Mark "${resourceTitle}" as studied?\n\nThis will add it to your study progress.`)) {
            const url = '/student/resources/' + resourceId + '/mark-studied';
            
            fetch(url, {
                method: 'POST',
                headers: {
                    'X-CSRF-TOKEN': '{{ csrf_token() }}',
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify({ duration: 15 })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Resource marked as studied successfully.');
                    // Change button style
                    this.style.background = '#10b981';
                    this.style.color = 'white';
                    this.disabled = true;
                    this.innerHTML = '<i class="fas fa-check"></i>';
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
            });
        }
    });
});
</script>
@endpush